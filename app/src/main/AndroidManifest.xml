<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <application
        android:name=".MITAttendanceApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@drawable/ic_icon"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@drawable/ic_icon"
        android:supportsRtl="true"
        android:theme="@style/Theme.MITAttendance"
        android:usesCleartextTraffic="true"
        tools:targetApi="31">

        <activity
            android:name=".ui.login.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.MITAttendance.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <meta-data
                android:name="android.app.shortcuts"
                android:resource="@xml/shortcuts" />
        </activity>

        <activity
            android:name=".ui.login.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.MITAttendance" />

        <activity
            android:name=".auth.LoginActivity"
            android:exported="false"
            android:label="ChatGPT Login"
            android:theme="@style/Theme.MITAttendance" />

        <activity
            android:name=".ui.subjects.SubjectsActivity"
            android:exported="false"
            android:label="My Attendance"
            android:theme="@style/Theme.MITAttendance" />

        <activity
            android:name=".ui.subjects.CustomizeActivity"
            android:exported="false"
            android:label="Customize"
            android:theme="@style/Theme.MITAttendance" />

        <activity
            android:name=".ui.subjects.ErpWebViewActivity"
            android:exported="false"
            android:label="ERP"
            android:parentActivityName=".ui.subjects.SubjectsActivity" />

        <activity
            android:name=".ui.subjects.ExamCellWebViewActivity"
            android:exported="false"
            android:label="Exam Cell"
            android:parentActivityName=".ui.subjects.SubjectsActivity" />

        <activity
            android:name=".ui.subjects.ExamCellLoginActivity"
            android:exported="false"
            android:label="Exam Cell Login"
            android:parentActivityName=".ui.subjects.SubjectsActivity" />

        <activity
            android:name=".ui.detail.AttendanceDetailActivity"
            android:exported="false"
            android:label="Attendance Details"
            android:parentActivityName=".ui.subjects.SubjectsActivity" />

        <activity
            android:name=".ui.practical.PracticalActivity"
            android:exported="false"
            android:label="Practicals"
            android:parentActivityName=".ui.subjects.SubjectsActivity" />

        <activity
            android:name=".ui.practical.PracticalListActivity"
            android:exported="false"
            android:label="Practical List"
            android:parentActivityName=".ui.practical.PracticalActivity" />

        <activity
            android:name=".ui.practical.SubmitPracticalActivity"
            android:exported="false"
            android:label="Submit Practical"
            android:parentActivityName=".ui.practical.PracticalListActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.practical.ChatGPTWebViewActivity"
            android:exported="false"
            android:label="ChatGPT AI"
            android:theme="@style/Theme.MITAttendance" />

        <activity
            android:name=".ui.chat.ChatActivity"
            android:exported="false"
            android:label="Public Chat"
            android:parentActivityName=".ui.subjects.SubjectsActivity"
            android:windowSoftInputMode="adjustResize" />

        <activity
            android:name=".ui.reviews.ReviewsActivity"
            android:exported="false"
            android:label="Reviews"
            android:parentActivityName=".ui.subjects.SubjectsActivity" />

        <activity
            android:name=".ui.timetable.TimetableActivity"
            android:exported="false"
            android:label="Timetable"
            android:parentActivityName=".ui.subjects.SubjectsActivity"
            android:theme="@style/Theme.MITAttendance" />

        <activity
            android:name=".ui.microsoft.MicrosoftLearnActivity"
            android:exported="false"
            android:label="Microsoft Learn"
            android:parentActivityName=".ui.certifications.CertificationsActivity"
            android:theme="@style/Theme.MITAttendance" />

        <activity
            android:name=".ui.certifications.CertificationsActivity"
            android:exported="false"
            android:label="Certifications"
            android:parentActivityName=".ui.subjects.SubjectsActivity"
            android:theme="@style/Theme.MITAttendance" />

        <activity
            android:name=".ui.agent.AgentActivity"
            android:exported="false"
            android:label="AI Agent"
            android:parentActivityName=".ui.subjects.SubjectsActivity"
            android:theme="@style/Theme.MITAttendance" />

        <activity
            android:name=".ui.agent.AgentFileExplorerActivity"
            android:exported="false"
            android:label="Agent Files"
            android:parentActivityName=".ui.agent.AgentActivity"
            android:theme="@style/Theme.MITAttendance" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.provider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths"
                tools:replace="android:resource" />
        </provider>

    </application>

</manifest>